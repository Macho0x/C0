#!/bin/sh
# Auto-increment VERSION file on every commit when it ends with -dev.
# Format: MAJOR.MINOR.PATCH-dev (e.g. 0.1.0-dev)
# Release versions (no -dev suffix) are left unchanged.

VERSION_FILE="VERSION"

if [ ! -f "$VERSION_FILE" ]; then
    echo "0.0.1-dev" > "$VERSION_FILE"
    git add "$VERSION_FILE"
    exit 0
fi

raw=$(cat "$VERSION_FILE" | tr -d '[:space:]')

# Do not bump tagged release versions (e.g. 1.8.0).
case "$raw" in
    *-dev) ;;
    *) exit 0 ;;
esac

version=$(echo "$raw" | sed 's/-dev//')

major=$(echo "$version" | cut -d. -f1)
minor=$(echo "$version" | cut -d. -f2)
patch=$(echo "$version" | cut -d. -f3)

# Increment patch
new_patch=$((patch + 1))
new_version="${major}.${minor}.${new_patch}-dev"

echo "$new_version" > "$VERSION_FILE"
git add "$VERSION_FILE"
