{
  "name": "goop",
  "displayName": "Goop Language Support",
  "description": "Syntax highlighting and LSP support for Goop, a statically typed language that compiles to Go",
  "version": "0.3.3",
  "publisher": "goop",
  "icon": "icons/goop-icon-square-transparentbg.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Macho0x/Goop.git",
    "directory": "editors/vscode"
  },
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:goop"
  ],
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "title": "Goop",
      "properties": {
        "goop.path": {
          "type": "string",
          "default": "",
          "description": "Path to the goop compiler binary. Leave empty to auto-detect (workspace/goop, then PATH)."
        }
      }
    },
    "languages": [
      {
        "id": "goop",
        "aliases": [
          "Goop",
          "goop"
        ],
        "extensions": [
          ".goop"
        ],
        "icon": {
          "light": "./icons/goop-icon-squarewords-transparentbg.png",
          "dark": "./icons/goop-icon-squarewords-transparentbg.png"
        },
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "goop",
        "scopeName": "source.goop",
        "path": "./syntaxes/goop.tmLanguage.json"
      }
    ],
    "iconThemes": [
      {
        "id": "goop-file-icons",
        "label": "Goop File Icons",
        "path": "./icons/goop-file-icon-theme.json"
      }
    ],
    "configurationDefaults": {
      "[goop]": {
        "editor.semanticHighlighting.enabled": false,
        "editor.tokenColorCustomizations": {
          "comments": "#6A9955",
          "keywords": "#C586C0",
          "strings": "#CE9178",
          "numbers": "#B5CEA8",
          "types": "#4EC9B0",
          "textMateRules": [
            {
              "scope": "entity.name.function.binding.goop",
              "settings": { "foreground": "#DCDCAA" }
            },
            {
              "scope": "constant.language.capital-identifier.goop, entity.name.type.goop",
              "settings": { "foreground": "#4EC9B0" }
            },
            {
              "scope": "entity.name.type.declaration.goop, entity.name.type.module.goop",
              "settings": { "foreground": "#4EC9B0", "fontStyle": "bold" }
            },
            {
              "scope": "storage.type.goop, support.type.goop",
              "settings": { "foreground": "#569CD6" }
            },
            {
              "scope": "keyword.operator.goop",
              "settings": { "foreground": "#D4D4D4" }
            },
            {
              "scope": "meta.embedded.block.golang",
              "settings": { "foreground": "#9CDCFE" }
            }
          ]
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node -e \"require('fs').accessSync('extension.js')\""
  },
  "dependencies": {
    "vscode-languageclient": "^8.0.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.88.0",
    "typescript": "^5.0.0"
  }
}
