{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Goop",
  "scopeName": "source.goop",
  "fileTypes": ["goop"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#embedded-golang" },
    { "include": "#strings" },
    { "include": "#bindings" },
    { "include": "#type-declarations" },
    { "include": "#operators" },
    { "include": "#keywords" },
    { "include": "#literals" },
    { "include": "#types" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.goop",
          "begin": "\\(\\*",
          "end": "\\*\\)",
          "patterns": [{ "include": "#comments" }]
        },
        {
          "name": "comment.line.goop",
          "match": "//.*$"
        }
      ]
    },

    "embedded-golang": {
      "patterns": [
        {
          "name": "meta.embedded.block.golang",
          "begin": "@golang\\s*\\{",
          "end": "\\}",
          "contentName": "source.go",
          "patterns": [{ "include": "source.go" }]
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.goop",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.goop",
              "match": "\\\\[ntr\"'\\\\]"
            }
          ]
        },
        {
          "name": "string.quoted.single.goop",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.goop",
              "match": "\\\\[ntr\"'\\\\]"
            }
          ]
        }
      ]
    },

    "bindings": {
      "patterns": [
        {
          "comment": "let binding with function name",
          "match": "\\b(let)\\b(\\s+)(rec\\s+)?([a-z_][a-zA-Z0-9_']*)",
          "captures": {
            "1": { "name": "keyword.goop" },
            "3": { "name": "keyword.goop" },
            "4": { "name": "entity.name.function.binding.goop" }
          }
        },
        {
          "comment": "val binding",
          "match": "\\b(val)\\b(\\s+)([a-z_][a-zA-Z0-9_']*)",
          "captures": {
            "1": { "name": "keyword.goop" },
            "3": { "name": "entity.name.function.binding.goop" }
          }
        },
        {
          "comment": "type name in declaration",
          "match": "\\b(type)\\b(\\s+)([a-z_][a-zA-Z0-9_']*)",
          "captures": {
            "1": { "name": "keyword.goop" },
            "3": { "name": "entity.name.type.declaration.goop" }
          }
        },
        {
          "comment": "module name",
          "match": "\\b(module)\\b(\\s+)([A-Z][a-zA-Z0-9_']*)",
          "captures": {
            "1": { "name": "keyword.goop" },
            "3": { "name": "entity.name.type.module.goop" }
          }
        }
      ]
    },

    "type-declarations": {
      "patterns": [
        {
          "comment": "ADT variant bar",
          "match": "(\\|)(\\s*)([A-Z][a-zA-Z0-9_']*)",
          "captures": {
            "1": { "name": "keyword.other.goop" },
            "3": { "name": "constant.language.capital-identifier.goop" }
          }
        },
        {
          "comment": "newtype constructor",
          "match": "\\b(newtype)\\b",
          "name": "keyword.goop"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.goop",
          "match": "->|=>|\\|>|::|\\?|\\^|\\+\\+|\\+\\.|\\*\\.|<>|<=|>=|==|!=|\\|\\||&&|[+\\-*/%.]"
        },
        {
          "name": "keyword.other.goop",
          "match": "(?<!\\[)(\\|)(?!\\])"
        },
        {
          "name": "keyword.other.goop punctuation.other.colon",
          "match": ":"
        },
        {
          "name": "keyword.other.goop punctuation.separator.semicolon",
          "match": ";"
        },
        {
          "name": "keyword.other.goop punctuation.separator.comma",
          "match": ","
        },
        {
          "name": "keyword.other.goop punctuation.other.period",
          "match": "\\."
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.other.goop",
          "match": "\\b(and|as|async|chan|else|fun|golang|go|goop|guard|if|import|in|is|match|mutable|of|panic|private|rec|region|result|return|select|then|type|using|val|when|where|with)\\b(?!')"
        },
        {
          "name": "keyword.goop",
          "match": "\\b(let|module)\\b(?!')"
        }
      ]
    },

    "literals": {
      "patterns": [
        {
          "name": "constant.language.boolean.goop",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.goop",
          "match": "\\b(None|Some|Ok|Error|unit)\\b"
        },
        {
          "name": "constant.numeric.decimal.float.goop",
          "match": "\\b[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.decimal.integer.goop",
          "match": "\\b[0-9]+\\b"
        },
        {
          "name": "constant.language.unit.goop",
          "match": "\\(\\)"
        },
        {
          "name": "constant.language.list.goop",
          "match": "\\[\\]"
        },
        {
          "name": "meta.brace.round.goop",
          "begin": "\\(",
          "end": "\\)",
          "patterns": [{ "include": "$self" }]
        },
        {
          "name": "meta.brace.curly.goop",
          "begin": "\\{",
          "end": "\\}",
          "patterns": [{ "include": "$self" }]
        },
        {
          "name": "meta.brace.square.goop",
          "begin": "\\[",
          "end": "\\]",
          "patterns": [{ "include": "$self" }]
        }
      ]
    },

    "types": {
      "patterns": [
        {
          "name": "storage.type.goop",
          "match": "'[a-z][a-zA-Z0-9_']*\\b|'_\\b"
        },
        {
          "name": "support.type.goop",
          "match": "\\b(bool|int|float|string|char|unit|bytes|rune|list|option|result|owned_chan|chan)\\b"
        },
        {
          "name": "entity.name.type.goop",
          "match": "\\b[A-Z][a-zA-Z0-9_']*\\b"
        }
      ]
    },

    "identifiers": {
      "patterns": [
        {
          "name": "constant.language.goop",
          "match": "\\b_\\b"
        },
        {
          "name": "constant.language.capital-identifier.goop",
          "match": "\\b[A-Z][a-zA-Z0-9_']*\\b"
        },
        {
          "name": "variable.other.goop",
          "match": "\\b[a-z_][a-zA-Z0-9_']*\\b"
        },
        {
          "name": "variable.other.property.goop",
          "match": "\\b[a-z_][a-zA-Z0-9_']*(?=\\s*;)"
        }
      ]
    }
  }
}
