{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Goop",
  "scopeName": "source.goop",
  "fileTypes": ["goop"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#embedded-golang" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.goop",
          "begin": "\\(\\*",
          "end": "\\*\\)",
          "patterns": [{ "include": "#comments" }]
        },
        {
          "name": "comment.line.goop",
          "match": "//.*$"
        }
      ]
    },
    "embedded-golang": {
      "patterns": [
        {
          "name": "meta.embedded.block.golang",
          "begin": "@golang\\s*\\{",
          "end": "\\}",
          "contentName": "source.go",
          "patterns": [{ "include": "source.go" }]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.goop",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.goop",
              "match": "\\\\[ntr\"'\\\\]"
            }
          ]
        },
        {
          "name": "string.quoted.single.goop",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.goop",
              "match": "\\\\[ntr\"'\\\\]"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.goop",
          "match": "\\b[0-9]+\\.[0-9]*(?:[eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.goop",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.goop",
          "match": "\\b(if|then|else|match|with|when|guard|of|in|let|rec|mutable|and|as|select|return|where|is|using)\\b"
        },
        {
          "name": "keyword.declaration.goop",
          "match": "\\b(module|import|type|val|fun|private|newtype)\\b"
        },
        {
          "name": "keyword.other.goop",
          "match": "\\b(golang|goop|go|chan|async|result|region|panic)\\b"
        },
        {
          "name": "constant.language.goop",
          "match": "\\b(true|false|unit|None|Some|Ok|Error)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "variable.language.typevar.goop",
          "match": "'[a-z][a-zA-Z0-9_']*"
        },
        {
          "name": "support.type.primitive.goop",
          "match": "\\b(bool|int|float|string|char|unit|bytes|rune|list|option|result|owned_chan)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.error-propagation.goop",
          "match": "\\?"
        },
        {
          "name": "keyword.operator.arrow.goop",
          "match": "->"
        },
        {
          "name": "keyword.operator.pipe.goop",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.fatarrow.goop",
          "match": "=>"
        },
        {
          "name": "keyword.operator.assignment.goop",
          "match": "="
        },
        {
          "name": "keyword.operator.comparison.goop",
          "match": "<>|<=|>=|<|>|==|!="
        },
        {
          "name": "keyword.operator.arithmetic.goop",
          "match": "\\+|\\-|\\*\\*|\\*|/\\.|\\*\\.|%|\\."
        },
        {
          "name": "keyword.operator.logical.goop",
          "match": "\\|\\||&&|!"
        },
        {
          "name": "keyword.operator.concatenation.goop",
          "match": "\\^"
        },
        {
          "name": "keyword.operator.cons.goop",
          "match": "::"
        },
        {
          "name": "keyword.operator.range.goop",
          "match": "\\.\\."
        },
        {
          "name": "punctuation.separator.dot.goop",
          "match": "\\."
        },
        {
          "name": "punctuation.separator.comma.goop",
          "match": ","
        },
        {
          "name": "punctuation.separator.semicolon.goop",
          "match": ";"
        },
        {
          "name": "punctuation.separator.colon.goop",
          "match": ":"
        },
        {
          "name": "punctuation.bracket.goop",
          "match": "[\\[\\]{}()|]"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "entity.name.type.constructor.goop",
          "match": "\\b[A-Z][a-zA-Z0-9_']*\\b"
        },
        {
          "name": "variable.goop",
          "match": "\\b[a-z_][a-zA-Z0-9_']*\\b"
        }
      ]
    }
  }
}
