module main

type User = { id: int; name: string }
type UserError = NotFound | InvalidInput of string

let findUser (id: int) : (User, UserError) result =
  if id < 0 then Error (InvalidInput "negative id")
  else if id = 42 then Ok { id = 42; name = "Alice" }
  else Error NotFound

let validateName (u: User) : (User, UserError) result =
  if u.name = "" then Error (InvalidInput "empty name")
  else Ok u

let loadUser (id: int) : (User, UserError) result =
  result {
    let! user = findUser id
    let! validated = validateName user
    return validated
  }

let getUserName (id: int) : string =
  match loadUser id with
  | Ok u -> u.name
  | Error NotFound -> "unknown"
  | Error (InvalidInput msg) -> "invalid: " ^ msg

let main () =
  print_line (getUserName 42)
