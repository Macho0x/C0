module main

(* Heap Buffer via ptr_of {} — no @[go] constructor. *)

import go "bytes" {
  type Buffer
  val (b : Buffer ptr).String : unit -> string
  val (b : Buffer ptr).WriteString : string -> ...any -> unit
}

let main () =
  let b : Buffer ptr = ptr_of {} in
  begin
    b.WriteString "hello from bytes.Buffer";
    assert (b.String () = "hello from bytes.Buffer")
  end
