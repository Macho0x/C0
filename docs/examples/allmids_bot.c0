module Trading.AllMidsBot

(* DESIGN SKETCH — does not compile with the current bootstrap compiler.

   AllMids WebSocket trading bot.
   Illustrates C0's extern Go interop with gorilla/websocket,
   JSON parsing, channel-based concurrency, and order placement.

   Target exchange: Hyperliquid (https://hyperliquid.xyz)
     WS  : wss://api.hyperliquid.xyz/ws
     REST: https://api.hyperliquid.xyz/info

   The allMids feed streams mid prices for every listed asset.
   We compute a fair value, detect deviation, and place a market
   order when the edge exceeds a threshold.

   NOTE: This example shows the intended C0 syntax for a real
   trading workflow. Some extern bindings (gorilla/websocket's
   dialer, encoding/json reflection, crypto signing) are simplified
   here — the compiler's extern interop is still maturing. *)

(* ------------------------------------------------------------------ *)
(* Extern Go bindings                                                  *)
(* ------------------------------------------------------------------ *)

extern "go" "github.com/gorilla/websocket" {
  (* The dialer dials a websocket URL and returns a connection. *)
  val Dialer : { url: string } -> { conn: conn; err: error } result
  (* ReadMessage blocks until a message arrives. *)
  val ReadMessage : conn -> { msg: bytes; err: error } result
  (* WriteJSON sends a value as JSON. *)
  val WriteJSON : conn -> 'a -> error option
  (* Close terminates the connection. *)
  val Close : conn -> unit
}

extern "go" "encoding/json" {
  (* Unmarshal parses JSON bytes into a C0 record. *)
  val Unmarshal : bytes -> 'a -> error option
  (* Marshal serialises a C0 record to JSON bytes. *)
  val Marshal : 'a -> { bytes: bytes; err: error } result
}

extern "go" "net/http" {
  val Post : string -> string -> bytes -> { resp: resp; err: error } result
}

extern "go" "fmt" {
  val Sprintf : string -> 'a -> string
}

(* ------------------------------------------------------------------ *)
(* Domain types                                                        *)
(* ------------------------------------------------------------------ *)

type side = Buy | Sell

type order_request =
  { asset: string
  ; isBuy: bool
  ; limitPx: float
  ; sz: float
  ; reduceOnly: bool
  }

type all_mids_msg =
  { channel: string
  ; data: { mids: (string * string) list }
  }

type market_state =
  { symbol: string
  ; mid: float
  ; samples: int
  ; fairValue: float
  }

(* ------------------------------------------------------------------ *)
(* Helpers                                                             *)
(* ------------------------------------------------------------------ *)

let parseFloat (s: string) : float =
  (* In a full implementation this would bind to strconv.ParseFloat. *)
  extern_go_parse_float s

let newMarket (sym: string) : market_state =
  { symbol = sym
  ; mid = 0.0
  ; samples = 0
  ; fairValue = 0.0
  }

(* Update the EWMA fair value from a fresh mid price. *)
let updateFairValue (mkt: market_state) (newMid: float) (alpha: float) : unit =
  if mkt.samples = 0 then (
    mkt.fairValue <- newMid
  ) else (
    mkt.fairValue <- alpha *. newMid +. (1.0 -. alpha) *. mkt.fairValue
  )
  mkt.mid <- newMid
  mkt.samples <- mkt.samples + 1

(* Decide whether to trade: if the live mid deviates from our
   fair value by more than the edge threshold, we place an order
   on the side that captures the dislocation. *)
let decide (mkt: market_state) (edgeBps: float) : order_request option =
  if mkt.fairValue <= 0.0 then None
  else
    let deviation = (mkt.mid -. mkt.fairValue) /. mkt.fairValue in
    let bps = deviation *. 10000.0 in
    if bps > edgeBps then
      (* Mid is too high → sell. *)
      Some { asset = mkt.symbol
           ; isBuy = false
           ; limitPx = mkt.mid
           ; sz = 0.01
           ; reduceOnly = false }
    else if bps < (0.0 -. edgeBps) then
      (* Mid is too low → buy. *)
      Some { asset = mkt.symbol
           ; isBuy = true
           ; limitPx = mkt.mid
           ; sz = 0.01
           ; reduceOnly = false }
    else None

(* ------------------------------------------------------------------ *)
(* WebSocket subscription                                             *)
(* ------------------------------------------------------------------ *)

let subscribeMsg : bytes =
  (* {"method":"subscribe","subscription":{"type":"allMids"}} *)
  extern_go_marshal_subscribe

let connect (url: string) : conn =
  match Dialer { url = url } with
  | Ok { conn = c } -> c
  | Error e -> panic (Sprintf "dial failed: %s" e)

(* ------------------------------------------------------------------ *)
(* Order placement (REST)                                              *)
(* ------------------------------------------------------------------ *)

let placeOrder (req: order_request) : unit =
  let body = match Marshal req with
    | Ok { bytes = b } -> b
    | Error e -> panic (Sprintf "marshal failed: %s" e)
  in
  match Post "https://api.hyperliquid.xyz/info" "application/json" body with
  | Ok { resp = _ } -> print_line ("order placed: " ^ req.asset)
  | Error e -> print_line ("order failed: " ^ e)

(* ------------------------------------------------------------------ *)
(* Main loop                                                           *)
(* ------------------------------------------------------------------ *)

let run (symbol: string) (edgeBps: float) : unit =
  let conn = connect "wss://api.hyperliquid.xyz/ws" in
  (* Subscribe to the allMids channel. *)
  let _ = WriteJSON conn subscribeMsg in
  let mkt = newMarket symbol in
  (* Spawn a goroutine that reads messages and sends parsed
     mids on a channel; the main loop consumes them. *)
  let mids = Chan.make () : float chan in
  let stop = Chan.make () : unit chan in
  let rec readerLoop () =
    match ReadMessage conn with
    | Ok { msg = bytes } ->
        (* Parse the allMids message and extract our symbol's mid. *)
        let parsed : all_mids_msg option =
          match Unmarshal bytes { channel = ""; data = { mids = [] } } with
          | None -> None
          | Some _ ->
              (* In a full implementation we'd walk the mids list
                 and find our symbol. Simplified here. *)
              Some { channel = "allMids"; data = { mids = [] } }
        in
        (match parsed with
         | Some msg when msg.channel = "allMids" ->
             (* Find our symbol in the mids list. *)
             let rec find (sym: string) (xs: (string * string) list) : float option =
               match xs with
               | [] -> None
               | (k, v) :: rest ->
                   if k = sym then Some (parseFloat v)
                   else find sym rest
             in
             (match find symbol msg.data.mids with
              | Some px -> Chan.send mids px
              | None -> ());
             readerLoop ()
         | _ -> readerLoop ())
    | Error e ->
        print_line ("read error: " ^ e);
        Chan.send stop ()
  in
  go readerLoop
  ;
  (* Main loop: consume mids, update fair value, decide, trade. *)
  let rec tradingLoop () =
    let px = Chan.recv mids in
    updateFairValue mkt px 0.05;
    (match decide mkt edgeBps with
     | Some order ->
         print_line (Sprintf "edge detected on %s, placing order" symbol);
         placeOrder order;
         tradingLoop ()
     | None -> tradingLoop ())
  in
  go tradingLoop
  ;
  let _ = Chan.recv stop in
  Close conn

let main () =
  (* Trade BTC with a 5 bps edge threshold. *)
  run "BTC" 5.0