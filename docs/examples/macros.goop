module main

type Status = Ok | Err of string

let describe (s: Status) : string =
  match s with
  | Ok -> "ok"
  | Err _ -> "not ok"

let message (s: Status) : string =
  match s with
  | Err msg -> msg
  | Ok -> "fine"

let handle (s: Status) : string =
  match s with
  | Err msg -> msg
  | Ok -> "no error"

let main () =
  let s = Ok in
  print_line (describe s)
