module main

(* Concurrency example: typed channel + goroutine send + recv.
   The annotation `: int chan` constrains the channel element type. *)

let compute () : int chan =
  let ch : int chan = Chan.make () in
  let dummy = go (fun () -> Chan.send ch 42) in
  ch

let main () : unit =
  let ch = compute () in
  let v = Chan.recv ch in
  assert (v = 42)
