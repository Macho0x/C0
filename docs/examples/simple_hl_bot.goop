module Trading.SimpleHLBot

type order_id = newtype string

type OrderAck =
  | Filled
  | Rejected
  | PartialFill

let handle (ack: OrderAck) : string =
  match ack with
  | Filled -> "filled"
  | Rejected -> "rejected"
  | PartialFill -> "partial"

let main () : unit with { io } =
  let oid = OrderId "hl-1" in
  print_line (handle Filled)
