module Trading.SimpleHLBot

type order_id = | Order_id of string

type OrderAck =
  | Filled
  | Rejected
  | PartialFill

let handle (ack: OrderAck) : string =
  match ack with
  | Filled -> "filled"
  | Rejected -> "rejected"
  | PartialFill -> "partial"

let main () : unit =
  let oid = Order_id "hl-1" in
  print_line (handle Filled)
