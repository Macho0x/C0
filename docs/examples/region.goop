module main

(* Declare a linear resource type *)
type Handle : 1

(* The Close function discharges a linear handle *)
let Close (h: Handle) : unit =
  print_line "resource closed"

(* A function that uses a handle *)
let useHandle (h: Handle) : unit =
  begin
    print_line "using handle";
    Close h
  end

(* Scoped resource management without region CE:
   use the handle, then Close discharges it. *)
let process (h: Handle) : unit =
  useHandle h

let main () =
  print_line "region demo"
