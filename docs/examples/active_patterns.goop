module main

type IntOption = | Some of { value: int } | None

let isPositive (n: int) : IntOption =
  if n > 0 then Some { value = n } else None

let isEven (n: int) : bool =
  n - (n / 2) * 2 = 0

let describe (n: int) : string =
  match isPositive n with
  | Some { value = p } when p > 100 -> "big positive"
  | Some { value = _ } -> "positive"
  | None when isEven n -> "even"
  | None -> "other"

let main () =
  print_line (describe 42)
