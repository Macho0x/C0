module main

(* Construct a slog.Handler implementor with ptr_of — no @[go] ctor. *)

import go "context" {
  type Context
}

import go "log/slog" {
  type Handler
  type Record
  type Attr
  type Level
  type Logger
  val New : Handler -> Logger
  val (l : Logger).Info : string -> unit
}

type capture = {
  mutable last : string;
}

implements Handler for capture with
  let Enabled (h : capture) (_ctx : Context) (_level : Level) : bool = true
  let Handle (h : capture) (_ctx : Context) (_r : Record) : error =
    begin
      h.last <- "ok";
      null
    end
  let WithAttrs (h : capture) (_attrs : Attr go_slice) : Handler =
    ptr_of { last = h.last }
  let WithGroup (h : capture) (_name : string) : Handler =
    ptr_of { last = h.last }
end

let main () =
  let h = ptr_of { last = "" } in
  let log = New h in
  begin
    log.Info "hi";
    assert (h.last = "ok")
  end
