module TradingDecisionLutTest

(* Inventory-aware market-making LUT — port of trading_decision_lut.ml
 * OCaml surface: Array.make · nested for · arr.(i) <- · set_decision · begin/end
 * 300 states: inv[5] x sig[5] x vol[4] x liq[3] *)

type side = Buy | Sell

type quote_params =
  { bid_offset_bps: int
  ; ask_offset_bps: int
  ; bid_size_mult: float
  ; ask_size_mult: float
  ; post_only: bool
  ; cancel_existing: bool
  ; take_liquidity: bool
  ; max_slippage_bps: int option
  }

type risk_action =
  | AllowNewPositions
  | ReduceOnly
  | ReduceOnlySide of side
  | FlattenAndPause
  | EmergencyReduce of side

type urgency = Low | Medium | High | Critical

type decision =
  { quote: quote_params option
  ; risk_action: risk_action
  ; urgency: urgency
  ; size_cap_pct_equity: float
  ; log_tag: string
  ; reason: string
  }

let dim_inv = 5
let dim_sig = 5
let dim_vol = 4
let dim_liq = 3
let lut_total_size = 300

let default_decision : decision =
  { quote = None
  ; risk_action = FlattenAndPause
  ; urgency = Critical
  ; size_cap_pct_equity = 0.0
  ; log_tag = "UNINITIALIZED"
  ; reason = "LUT not populated yet"
  }

let abs_int (x: int) : int =
  if x < 0 then 0 - x else x

let clamp (x: int) (lo: int) (hi: int) : int =
  if x < lo then lo else if x > hi then hi else x

(* inv varies fastest for cache locality *)
let lut_index (inv: int) (sig_: int) (vol: int) (liq: int) : int =
  let i_inv = inv + 2 in
  let i_sig = sig_ + 2 in
  i_inv + (i_sig * 5) + (vol * 25) + (liq * 100)

(* ------ Discretization (float feeds -> integer buckets) ------ *)

let bucket_inventory (current_pos: float) (max_abs_position: float) : int =
  if max_abs_position <= 0.0 then 0
  else
    let ratio = current_pos /. max_abs_position in
    if ratio >= 0.65 then 2
    else if ratio >= 0.25 then 1
    else if ratio <= (0.0 -. 0.65) then -2
    else if ratio <= (0.0 -. 0.25) then -1
    else 0

let bucket_signal (raw_score: float) : int =
  if raw_score >= 1.5 then 2
  else if raw_score >= 0.5 then 1
  else if raw_score <= (0.0 -. 1.5) then -2
  else if raw_score <= (0.0 -. 0.5) then -1
  else 0

let bucket_volatility (vol_zscore: float) : int =
  if vol_zscore >= 2.5 then 3
  else if vol_zscore >= 1.0 then 2
  else if vol_zscore >= (0.0 -. 0.5) then 1
  else 0

let bucket_liquidity (spread_bps: float) (avg_spread_bps: float) (depth_usd: float) : int =
  let spread_ratio = spread_bps /. avg_spread_bps in
  if spread_ratio <= 0.7 && depth_usd > 500000.0 then 0
  else if spread_ratio <= 1.4 && depth_usd > 150000.0 then 1
  else 2

let no_slippage : int option = None

let base_offset_bps (vol: int) : int =
  if vol = 0 then 4
  else if vol = 1 then 7
  else if vol = 2 then 14
  else if vol = 3 then 25
  else 10

let base_size_mult (vol: int) (liq: int) : float =
  if vol = 3 then 0.25
  else if liq = 2 then 0.45
  else if vol = 2 && liq = 1 then 0.55
  else 1.0

let pick_risk_action (inv: int) (extreme_inv: bool) (conflict: bool) : risk_action =
  if extreme_inv && conflict then ReduceOnly
  else if extreme_inv then ReduceOnly
  else if abs_int inv = 1 && conflict then ReduceOnly
  else AllowNewPositions

let pick_urgency (inv: int) (extreme_inv: bool) (conflict: bool) : urgency =
  if extreme_inv && conflict then High
  else if extreme_inv then Medium
  else if abs_int inv = 1 && conflict then Medium
  else Low

let pick_extra_cap (inv: int) (extreme_inv: bool) (conflict: bool) : float =
  if extreme_inv && conflict then 0.4
  else if extreme_inv then 0.6
  else if abs_int inv = 1 && conflict then 0.7
  else 1.0

let skew_bid_mult (net_scaled: int) (reduce_long: bool) (reduce_short: bool) : float =
  if net_scaled > 35 then 1.35
  else if net_scaled < -35 then 0.55
  else if reduce_long then 0.70
  else if reduce_short then 1.40
  else 1.0

let skew_ask_mult (net_scaled: int) (reduce_long: bool) (reduce_short: bool) : float =
  if net_scaled > 35 then 0.55
  else if net_scaled < -35 then 1.35
  else if reduce_long then 1.40
  else if reduce_short then 0.70
  else 1.0

let skew_bid_off_adj (net_scaled: int) (reduce_long: bool) (reduce_short: bool) : int =
  if net_scaled > 35 then -2
  else if net_scaled < -35 then 3
  else if reduce_long then 4
  else if reduce_short then -3
  else 0

let skew_ask_off_adj (net_scaled: int) (reduce_long: bool) (reduce_short: bool) : int =
  if net_scaled > 35 then 3
  else if net_scaled < -35 then -2
  else if reduce_long then -3
  else if reduce_short then 4
  else 0

let slippage_limit (take: bool) (bps: int) : int option =
  if take then Some (bps * 3) else no_slippage

let log_tag_for (inv: int) (sig_: int) (vol: int) (extreme_inv: bool) (conflict: bool) : string =
  if extreme_inv then "EXTREME_INV"
  else if conflict then "CONFLICT"
  else if abs_int sig_ = 2 then "STRONG_SIG"
  else if vol >= 2 then "HIGH_VOL"
  else "NORMAL"

let size_cap_for (vol: int) (extra_cap: float) : float =
  if vol = 3 then 0.005
  else if vol = 2 then 0.012
  else 0.025 *. extra_cap

(* ------ Core base decision (integer-scaled net_bias: sig*55 - inv*85) ------ *)

let compute_base_decision (inv: int) (sig_: int) (vol: int) (liq: int) : decision =
  let net_scaled = (sig_ * 55) - (inv * 85) in
  let long_inv = inv > 0 in
  let short_inv = inv < 0 in
  let buy_signal = sig_ > 0 in
  let sell_signal = sig_ < 0 in
  let reduce_long_aligned = long_inv && sell_signal in
  let reduce_short_aligned = short_inv && buy_signal in
  let conflict = (long_inv && buy_signal) || (short_inv && sell_signal) in
  let extreme_inv = abs_int inv = 2 in
  let offset_bps = base_offset_bps vol in
  let size_mult = base_size_mult vol liq in
  let risk_action = pick_risk_action inv extreme_inv conflict in
  let urgency = pick_urgency inv extreme_inv conflict in
  let extra_cap = pick_extra_cap inv extreme_inv conflict in
  let take_liq =
    (extreme_inv && (reduce_long_aligned || reduce_short_aligned)) ||
    (abs_int sig_ = 2 && abs_int inv <= 1 && liq <= 1)
  in
  let bid_mult = skew_bid_mult net_scaled reduce_long_aligned reduce_short_aligned in
  let ask_mult = skew_ask_mult net_scaled reduce_long_aligned reduce_short_aligned in
  let bid_off_adj = skew_bid_off_adj net_scaled reduce_long_aligned reduce_short_aligned in
  let ask_off_adj = skew_ask_off_adj net_scaled reduce_long_aligned reduce_short_aligned in
  let final_bid_mult = size_mult *. bid_mult in
  let final_ask_mult = size_mult *. ask_mult in
  let qparams =
    { bid_offset_bps = offset_bps + bid_off_adj
    ; ask_offset_bps = offset_bps + ask_off_adj
    ; bid_size_mult = final_bid_mult
    ; ask_size_mult = final_ask_mult
    ; post_only = not take_liq
    ; cancel_existing = extreme_inv || (abs_int sig_ = 2)
    ; take_liquidity = take_liq
    ; max_slippage_bps = slippage_limit take_liq offset_bps
    }
  in
  let tag = log_tag_for inv sig_ vol extreme_inv conflict in
  let reason =
    "inv=" ^ int_to_string inv ^ " sig=" ^ int_to_string sig_ ^
    " vol=" ^ int_to_string vol ^ " liq=" ^ int_to_string liq ^
    " net_scaled=" ^ int_to_string net_scaled
  in
  { quote = Some qparams
  ; risk_action = risk_action
  ; urgency = urgency
  ; size_cap_pct_equity = size_cap_for vol extra_cap
  ; log_tag = tag
  ; reason = reason
  }

