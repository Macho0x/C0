(* ------ LUT API (OCaml-style set_decision + nested for populate) ------ *)

let set_decision (lut: decision array) (inv: int) (sig_: int) (vol: int) (liq: int) (dec: decision) =
  lut.(lut_index inv sig_ vol liq) <- dec

let apply_overrides (lut: decision array) : decision array =
  begin
    lut.(lut_index 2 (-2) 0 0) <- override_extreme_long_strong_sell;
    lut.(lut_index 2 (-1) 1 1) <- override_extreme_long_adverse;
    lut.(lut_index 2 1 1 0) <- override_extreme_long_conflict;
    lut.(lut_index 2 2 2 1) <- override_extreme_long_hv_conflict;
    lut.(lut_index (-2) 2 0 0) <- override_extreme_short_strong_buy;
    lut.(lut_index (-2) 1 1 1) <- override_extreme_short_adverse;
    lut.(lut_index 0 2 1 0) <- override_neutral_strong_buy;
    lut.(lut_index 0 (-2) 0 1) <- override_neutral_strong_sell;
    lut.(lut_index 1 0 3 1) <- override_high_vol_defensive;
    lut.(lut_index 0 1 1 2) <- override_wide_liq_caution;
    lut
  end

let fill_base_lut (lut: decision array) : decision array =
  begin
    for liq = 0 to 2 do
      for vol = 0 to 3 do
        for s = -2 to 2 do
          for i = -2 to 2 do
            lut.(lut_index i s vol liq) <- compute_base_decision i s vol liq
          done
        done
      done
    done;
    apply_overrides lut
  end

let populate () : decision array =
  let lut = Array.make lut_total_size default_decision in
  fill_base_lut lut

let lookup (lut: decision array) (inv: int) (sig_: int) (vol: int) (liq: int) : decision =
  let i = clamp inv (-2) 2 in
  let s = clamp sig_ (-2) 2 in
  let v = clamp vol 0 3 in
  let l = clamp liq 0 2 in
  lut.(lut_index i s v l)

let rec assert_all_filled (lut: decision array) (i: int) : bool =
  if i >= lut_total_size then true
  else
    let d = lut.(i) in
    if d.log_tag = "UNINITIALIZED" then false
    else assert_all_filled lut (i + 1)

let main () =
  begin
    let lut = populate () in
    assert (Array.length lut = lut_total_size);
    assert (assert_all_filled lut 0);
    let d_neutral = lookup lut 0 0 1 1 in
    assert (d_neutral.log_tag <> "UNINITIALIZED");
    let d_long_sell = lookup lut 2 (-2) 0 0 in
    assert (d_long_sell.log_tag = "OVERRIDE:EXTREME_LONG_VS_STRONG_SELL");
    let d_conflict = lookup lut 2 2 2 1 in
    assert (d_conflict.log_tag = "OVERRIDE:EXTREME_LONG_HIGH_VOL_CONFLICT");
    let d_short_buy = lookup lut (-2) 2 0 0 in
    assert (d_short_buy.log_tag = "OVERRIDE:EXTREME_SHORT_VS_STRONG_BUY");
    let inv_b = bucket_inventory 18750.0 50000.0 in
    let sig_b = bucket_signal 1.8 in
    let vol_b = bucket_volatility 1.7 in
    let liq_b = bucket_liquidity 9.5 7.0 420000.0 in
    assert (inv_b = 1);
    let d_bucket = lookup lut inv_b sig_b vol_b liq_b in
    assert (d_bucket.log_tag <> "UNINITIALIZED")
  end
