module Main

type OrderAck =
  | Filled of { order_id: string; qty: int }
  | Rejected of { reason: string }
  | PartialFill of { order_id: string; filled: int; remaining: int }

let handleAck (ack: OrderAck) : string =
  match ack with
  | OrderAck.Filled { order_id; qty } -> "filled " ^ order_id ^ " x" ^ int_to_string qty
  | OrderAck.Rejected { reason } -> "rejected: " ^ reason
  | OrderAck.PartialFill { order_id; filled; remaining } ->
      "partial " ^ order_id ^ " " ^ int_to_string filled ^ "/" ^ int_to_string remaining

let main () : unit with { io } =
  begin
    let a = OrderAck.Filled { order_id = "o1"; qty = 10 } in
    print_line (handleAck a)
  end
