module MatchWhenTest

type opt_int = | Some of int | None

let describe (x: opt_int) : string =
  match x with
  | Some n when n > 100 -> "big"
  | Some n when n > 0 -> "positive"
  | Some _ -> "zero or negative"
  | None -> "none"

let main () =
  let chk1 = assert (describe (Some 500) = "big") in
  let chk2 = assert (describe (Some 42) = "positive") in
  let chk3 = assert (describe (Some 0) = "zero or negative") in
  let chk4 = assert (describe (Some (-1)) = "zero or negative") in
  assert (describe None = "none")
